<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta content="Legal Code of the Celtic Nation" property="og:title" />
    <meta content="Browse through the interactive legislative records of Democraciv MK13." property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="https://laws.democraciv.com" property="og:url" />
    <meta content="#74c887" data-react-helmet="true" name="theme-color" />  <!-- 59896b -->
    <meta property="og:image" content="https://cdn.democraciv.com/static/mk13/nation-logo.png" />

    <link rel="icon" type="image/x-icon" href="/static/favicon.ico">
    <title>{% block title %}Democraciv MK13{% endblock title %}</title>

    <link rel="stylesheet" href="/static/pico.jade.min.css">
    <link rel="stylesheet" href="/static/style.min.css">

    {% block extra_head %}{% endblock extra_head %}
</head>

<body>
    <header class="site-header">
        <nav class="site-nav" aria-label="Main navigation">
            <a href="/" class="brand">
                <img
                    class="brand-logo"
                    src="/static/dciv_small.gif"
                    alt="Democraciv Logo"
                >
                <span class="brand-title">
                    <strong>Democraciv MK13</strong>
                    <small>The Celtic Nation</small>
                </span>
            </a>

            <button
                type="button"
                class="nav-toggle"
                aria-expanded="false"
                aria-controls="site-menu"
            >
                <span class="sr-only">Toggle navigation</span>
                <span class="nav-toggle-box" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </button>

            <div class="top-links" id="site-menu">
                <a href="/law">Laws</a>
                <a href="/legal-code">Legal Code</a>
                <a href="/bill">Bills</a>
                <a href="/motion">Motions</a>
            </div>
        </nav>
    </header>

    <main class="page {% block page_class %}{% endblock page_class %}">
        {% block content %}{% endblock content %}
    </main>

    <footer class="site-footer" style="margin-top: 2rem;">
        <p>Made with ❤️ by Jonas (DerJonas – u/Jovanos). <a href="https://github.com/jonasbohmann/democraciv-discord-bot" target="_blank" rel="noopener noreferrer">Source.</a></p>
        <div class="keyline" aria-hidden="true" style="margin-top: 1.5rem; margin-bottom: 1.5rem;"></div>
        <p class="small record-subtle" style="margin-top: 0.5rem;">All content is fictional and intended for roleplay purposes only. User submissions do not represent the views of the site operator. Content reported as unlawful will be reviewed and removed where appropriate.</p>
        <p class="small record-subtle" style="margin-top: 0.5rem;">Alle Inhalte dienen ausschließlich fiktiven Rollenspielzwecken. Nutzerbeiträge geben nicht die Meinung des Betreibers wieder. Rechtswidrige Inhalte werden nach Hinweis entfernt.</a></p>
    </footer>

    <script>
        (() => {
            const mediaQuery = window.matchMedia("(max-width: 640px)");
            const nav = document.querySelector(".site-nav");
            const toggle = document.querySelector(".nav-toggle");
            const menu = document.getElementById("site-menu");

            if (!nav || !toggle || !menu) {
                return;
            }

            const closeMenu = () => {
                nav.classList.remove("is-menu-open");
                toggle.setAttribute("aria-expanded", "false");
                if (mediaQuery.matches) {
                    menu.hidden = true;
                }
            };

            const syncMenu = () => {
                if (mediaQuery.matches) {
                    if (!nav.classList.contains("is-menu-open")) {
                        menu.hidden = true;
                        toggle.setAttribute("aria-expanded", "false");
                    }
                } else {
                    nav.classList.remove("is-menu-open");
                    menu.hidden = false;
                    toggle.setAttribute("aria-expanded", "false");
                }
            };

            toggle.addEventListener("click", () => {
                const isOpen = nav.classList.toggle("is-menu-open");
                toggle.setAttribute("aria-expanded", String(isOpen));
                menu.hidden = !isOpen;
            });

            menu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    if (mediaQuery.matches) {
                        closeMenu();
                    }
                });
            });

            document.addEventListener("keydown", (event) => {
                if (event.key === "Escape") {
                    closeMenu();
                }
            });

            if (typeof mediaQuery.addEventListener === "function") {
                mediaQuery.addEventListener("change", syncMenu);
            } else {
                mediaQuery.addListener(syncMenu);
            }

            syncMenu();
        })();
    </script>

    {% block extra_scripts %}{% endblock extra_scripts %}
</body>
</html>
